    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.1.2",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "razorpay": "^2.9.2",
    "redis": "^4.6.11",
    "socket.io": "^4.7.2",
    "bullmq": "^5.3.3",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.3",
    "node-cron": "^3.0.3",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
